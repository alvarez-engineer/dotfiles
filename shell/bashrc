# shellcheck shell=bash
# Managed ~/.bashrc — symlinked from the dotfiles repo (shell module).
# Edit the repo file, not the symlink. Machine-local tweaks: ~/.bashrc.local

# Only continue for interactive shells.
case $- in
  *i*) ;;
  *) return ;;
esac

# --- Fedora / distro defaults (keep these so system behavior is preserved) ---
if [ -f /etc/bashrc ]; then
  . /etc/bashrc
fi

if ! [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]; then
  PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

if [ -d "$HOME/.bashrc.d" ]; then
  for rc in "$HOME"/.bashrc.d/*; do
    [ -f "$rc" ] && . "$rc"
  done
  unset rc
fi

# --- Dotfiles modules (resolve the repo dir via this file's real path) ---
__dotfiles_shell="$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
for __f in exports.sh aliases.sh functions.sh; do
  [ -r "$__dotfiles_shell/$__f" ] && . "$__dotfiles_shell/$__f"
done
unset __f

# --- History ---
HISTSIZE=50000
HISTFILESIZE=100000
HISTCONTROL=ignoreboth:erasedups
HISTIGNORE="ls:ll:la:cd:pwd:clear:history:exit"
shopt -s histappend 2>/dev/null
shopt -s checkwinsize 2>/dev/null
shopt -s cdspell dirspell autocd 2>/dev/null

# --- Completion ---
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# --- fzf key bindings / completion, if installed ---
if command -v fzf >/dev/null 2>&1; then
  # fzf >= 0.48 ships shell integration via `fzf --bash`.
  if fzf --bash >/dev/null 2>&1; then
    eval "$(fzf --bash)"
  else
    [ -f /usr/share/fzf/shell/key-bindings.bash ] && . /usr/share/fzf/shell/key-bindings.bash
    [ -f /usr/share/fzf/shell/completion.bash ] && . /usr/share/fzf/shell/completion.bash
  fi
fi

# --- agent-sandbox completion (when the repo is checked out) ---
# $AGENT_SANDBOX_HOME is set by exports.sh, sourced above.
[ -r "${AGENT_SANDBOX_HOME:-}/completions/agent-sandbox.bash" ] \
  && . "$AGENT_SANDBOX_HOME/completions/agent-sandbox.bash"

# --- Prompt: Starship if available, otherwise the bundled muted prompt ---
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"
elif [ -r "$__dotfiles_shell/prompt/bash_prompt.sh" ]; then
  . "$__dotfiles_shell/prompt/bash_prompt.sh"
fi

# --- Machine-local overrides (untracked) ---
[ -r "$HOME/.bashrc.local" ] && . "$HOME/.bashrc.local"
