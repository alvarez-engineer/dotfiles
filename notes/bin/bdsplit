#!/usr/bin/env bash
set -euo pipefail

# bdsplit — route marked lines out of brain dumps into the standing lists.
#
# Markers (line start, at most 3 leading spaces):
#   [] text      ->  todo.md          (appended as "- [ ] text")
#   ? text       ->  questions.md     (appended as "- text")
#   ! text       ->  remember.md      (appended as "- text")
#   ~ text       ->  optimizations.md (appended as "- text")
#
# The todo marker also accepts "[ ]", "- []" and "- [ ]" — the last is what
# todo.md already contains and what an editor's checkbox support writes. All
# four normalize to "- [ ] text" on the way out.
#
# Lines inside ``` / ~~~ fences and inside leading YAML frontmatter are ignored,
# as are already-checked "- [x]" items. Everything else stays in the dump.
#
# A routed dump moves to archive/<YYYY-MM>/, which is what makes re-running safe:
# it is no longer in inbox/, so it cannot be routed twice. That also means every
# file bdsplit reads is a file bdsplit archives, which is why an explicit FILE
# argument must live in inbox/ — see the guard below. A dump with prose but
# no markers is left in inbox/ untouched — routing is the "I'm finished" signal,
# and an unfinished dump must stay where bdsplit will look at it again. The one
# exception is a dump with nothing in it at all (see is_empty): there is no
# unfinished thought to protect, so it is archived rather than parked forever.
#
# `~` exists so "this produced nothing" is sayable. Without it, a finished dump
# and an unfinished one are the same file, and the grammar quietly implies every
# dump must yield a todo, a question, or a fact.

NOTES_DIR="${NOTES_DIR:-$HOME/notes}"

usage() {
  cat <<'EOF'
Usage: bdsplit [OPTIONS] [FILE ...]

Routes marked lines out of brain dumps into todo.md, questions.md, remember.md
and optimizations.md, then archives each dump it routed. With no FILE, processes
every *.md in $NOTES_DIR/inbox. A FILE outside inbox/ is refused: routing
archives the file it reads, so `bdsplit todo.md` would file your todo list away.

Options:
  --dry-run    print what would be routed and moved, change nothing
  --commit     git commit the result in $NOTES_DIR
  --push       implies --commit, then git push
  --keep       route but leave the dump in inbox/ (backlinks point at inbox/).
               Archiving is what makes re-running safe, so a kept dump routes
               again — and duplicates — on the next run. For a look before you
               leap, use --dry-run.
  -h, --help   show this help

Environment:
  NOTES_DIR    notes root (default: ~/notes)

Markers, with at most 3 leading spaces:
  [] text      -> todo.md           (also "[ ]", "- []", "- [ ]"; "[x]" skipped)
  ? text       -> questions.md
  ! text       -> remember.md
  ~ text       -> optimizations.md  ("that meeting produced nothing")

A dump with prose but no markers stays in inbox/ — you are still writing it.
A dump with nothing in it but frontmatter is archived.
EOF
}

dry_run="false"
do_commit="false"
do_push="false"
keep="false"
files=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) dry_run="true"; shift ;;
    --commit)  do_commit="true"; shift ;;
    --push)    do_push="true"; do_commit="true"; shift ;;
    --keep)    keep="true"; shift ;;
    -h|--help) usage; exit 0 ;;
    -*)        echo "bdsplit: unknown option: $1" >&2; usage >&2; exit 2 ;;
    *)         files+=("$1"); shift ;;
  esac
done

run() {
  if [[ "$dry_run" == "true" ]]; then
    printf 'DRY RUN: %s\n' "$*"
  else
    "$@"
  fi
}

[[ -d "$NOTES_DIR" ]] || { echo "bdsplit: no notes dir: $NOTES_DIR" >&2; exit 1; }

inbox="$NOTES_DIR/inbox"
[[ -d "$inbox" ]] || { echo "bdsplit: no inbox: $inbox" >&2; exit 1; }

# resolve_dir DIR — absolute, symlink-free path. `cd -P && pwd` rather than
# realpath(1) or `readlink -f`, neither of which is on a stock macOS.
resolve_dir() { (cd -P -- "$1" 2>/dev/null && pwd); }

inbox_real="$(resolve_dir "$inbox")" \
  || { echo "bdsplit: cannot resolve inbox: $inbox" >&2; exit 1; }

if [[ ${#files[@]} -eq 0 ]]; then
  # Nullglob so an empty inbox yields an empty array rather than a literal glob.
  shopt -s nullglob
  files=("$inbox"/*.md)
  shopt -u nullglob
else
  # Routing *archives the file it reads*, so an explicit FILE must be an inbox
  # dump. Two ways that bites otherwise, both silent:
  #
  #   bdsplit todo.md         re-routes every "- [ ]" back into todo.md, then
  #                           moves todo.md into archive/ — the standing list is
  #                           gone. Harmless on a fresh todo.md (no items, no
  #                           markers), so it only fires once you have something
  #                           to lose. `bdsplit *.md` from $NOTES_DIR gets here.
  #
  #   bdsplit archive/…/x.md  appends x.md's items a second time, then dies on
  #                           `mv: same file` — after the destinations are dirty.
  #
  # Compare resolved parent dirs, so a relative path, a trailing "./", or a
  # symlinked $NOTES_DIR all land on the same answer.
  for f in "${files[@]}"; do
    [[ -e "$f" ]] || { echo "bdsplit: no such file: $f" >&2; exit 1; }
    parent="$(resolve_dir "$(dirname -- "$f")")" \
      || { echo "bdsplit: cannot resolve: $f" >&2; exit 1; }
    if [[ "$parent" != "$inbox_real" ]]; then
      echo "bdsplit: not an inbox dump: $f" >&2
      echo "bdsplit: only files in $inbox can be routed (routing archives the file it reads)" >&2
      exit 2
    fi
  done
fi

if [[ ${#files[@]} -eq 0 ]]; then
  echo "nothing to route (inbox is empty)"
  exit 0
fi

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

# extract FILE — emit "<dest>\t<formatted line>" for each marked line.
extract() {
  awk '
    function trim(s) { sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s }
    BEGIN { in_fence = 0; in_fm = 0 }

    # Leading YAML frontmatter: only when --- is the very first line.
    NR == 1 && /^---[ \t]*$/ { in_fm = 1; next }
    in_fm && /^---[ \t]*$/   { in_fm = 0; next }
    in_fm                    { next }

    {
      # Position of the first non-space character; 0 when the line is all spaces.
      # A leading tab lands here as indent 0 with a tab in rest, which then fails
      # every marker test below — tabs are not a marker indent.
      p = match($0, /[^ ]/)
      if (p == 0) next
      indent = p - 1
      rest = substr($0, p)
    }

    # Fence toggles. Checked before the indent cutoff so a fence opened at any
    # indent still closes correctly.
    rest ~ /^```/ || rest ~ /^~~~/ { in_fence = !in_fence; next }
    in_fence { next }

    # Markdown treats 4+ spaces as an indented code block.
    indent > 3 { next }

    # Checked items first — an already-done todo is not a todo.
    rest ~ /^(- )?\[[xX]\][ \t]/ { next }

    # "[]", "[ ]", "- []" and "- [ ]" all mean the same thing. match() sets
    # RLENGTH to the width of whichever form was used, so one rule strips them
    # all and re-emits the canonical "- [ ] text".
    rest ~ /^(- )?\[ ?\][ \t]/ {
      match(rest, /^(- )?\[ ?\]/)
      print "todo\t- [ ] " trim(substr(rest, RLENGTH + 1))
      next
    }

    # None of these three is markdown syntax at line start, so none can be
    # scraped out of ordinary prose. "~ x" is safe in particular because a fence
    # needs three tildes, and the fence rule above has already consumed those.
    rest ~ /^\?[ \t]/ { print "questions\t- " trim(substr(rest, 2)); next }
    rest ~ /^![ \t]/  { print "remember\t- " trim(substr(rest, 2)); next }
    rest ~ /^~[ \t]/  { print "optimizations\t- " trim(substr(rest, 2)); next }
  ' "$1"
}

# is_empty FILE — true when nothing but leading frontmatter and blank lines.
#
# `bd` writes the template *before* handing the file to $EDITOR, so quitting
# without typing leaves a dump nobody wrote. It has no markers, so it is not
# routed; it has no prose, so leaving it in inbox/ protects nothing. Archive it.
#
# An unterminated frontmatter block (`---` opened, never closed) reads as empty
# here because every line is swallowed by in_fm. Call that non-empty instead:
# leaving a dump in inbox/ is the recoverable mistake, archiving one is not.
is_empty() {
  awk '
    BEGIN { in_fm = 0; body = 0 }
    NR == 1 && /^---[ \t]*$/ { in_fm = 1; next }
    in_fm && /^---[ \t]*$/   { in_fm = 0; next }
    in_fm                    { next }
    /[^ \t]/                 { body = 1; exit }
    END { exit (body || in_fm) ? 1 : 0 }
  ' "$1"
}

# archive_dump FILE MONTH BASE
archive_dump() {
  run mkdir -p "$NOTES_DIR/archive/$2"
  run mv -- "$1" "$NOTES_DIR/archive/$2/$3"
}

# ensure_list_gap FILE — markdown only renders a list as a list when a blank line
# separates it from a preceding paragraph. Destinations start with prose, so the
# first routed entry needs a gap; later ones are already inside the list.
ensure_list_gap() {
  local f="$1" last
  [[ -s "$f" ]] || return 0
  # A trailing newline first, or the append would join the last line.
  [[ -z "$(tail -c 1 -- "$f")" ]] || printf '\n' >>"$f"
  last="$(tail -n 1 -- "$f")"
  [[ -n "$last" ]] || return 0
  # Already inside a list: "- item" or an indented continuation/backlink.
  [[ "$last" =~ ^(-[[:space:]]|[[:space:]]) ]] && return 0
  printf '\n' >>"$f"
}

routed_total=0
routed_files=0
skipped=0
emptied=0

for f in "${files[@]}"; do
  if [[ ! -f "$f" ]]; then
    echo "bdsplit: not a file, skipping: $f" >&2
    continue
  fi

  base="$(basename -- "$f")"

  # Archive under the dump's own month, taken from its filename, not today's
  # date — routing an old dump should file it where it belongs.
  if [[ "$base" =~ ^([0-9]{4}-[0-9]{2})-[0-9]{2} ]]; then
    month="${BASH_REMATCH[1]}"
  else
    month="$(date +%Y-%m)"
  fi

  # Route first, into a temp file. Only once that succeeds do we touch the
  # destinations or move the source, so a failure leaves the dump in inbox/.
  hits="$tmp/hits"
  extract "$f" >"$hits"

  count="$(wc -l <"$hits" | tr -d ' ')"
  if [[ "$count" -eq 0 ]]; then
    if ! is_empty "$f"; then
      echo "skip: $base (no markers)"
      skipped=$((skipped + 1))
    elif [[ "$keep" == "true" ]]; then
      # --keep means "move nothing", and an empty dump has nothing to route, so
      # there is no work left to do on it at all.
      echo "empty: $base (kept)"
      skipped=$((skipped + 1))
    else
      echo "empty: $base -> archive/$month/"
      archive_dump "$f" "$month" "$base"
      emptied=$((emptied + 1))
    fi
    continue
  fi

  if [[ "$keep" == "true" ]]; then
    backlink="inbox/$base"
  else
    backlink="archive/$month/$base"
  fi

  if [[ "$dry_run" == "true" ]]; then
    printf 'route: %s (%s item(s))\n' "$base" "$count"
    while IFS=$'\t' read -r dest line; do
      printf '  -> %-16s %s\n' "$dest.md" "$line"
    done <"$hits"
  else
    while IFS=$'\t' read -r dest line; do
      ensure_list_gap "$NOTES_DIR/$dest.md"
      printf '%s\n      <!-- %s -->\n' "$line" "$backlink" >>"$NOTES_DIR/$dest.md"
    done <"$hits"
    printf 'route: %s (%s item(s))\n' "$base" "$count"
  fi

  if [[ "$keep" != "true" ]]; then
    archive_dump "$f" "$month" "$base"
  fi

  routed_total=$((routed_total + count))
  routed_files=$((routed_files + 1))
done

if [[ "$routed_files" -eq 0 && "$emptied" -eq 0 ]]; then
  if [[ "$skipped" -gt 0 ]]; then
    echo "nothing to route ($skipped dump(s) had no markers)"
  else
    echo "nothing to route"
  fi
  exit 0
fi

if [[ "$routed_files" -gt 0 ]]; then
  printf 'routed %d item(s) from %d dump(s)\n' "$routed_total" "$routed_files"
fi
if [[ "$emptied" -gt 0 ]]; then
  printf 'archived %d empty dump(s)\n' "$emptied"
fi

if [[ "$do_commit" == "true" ]]; then
  if ! git -C "$NOTES_DIR" rev-parse --git-dir >/dev/null 2>&1; then
    echo "bdsplit: --commit: $NOTES_DIR is not a git repo" >&2
    exit 1
  fi
  if [[ "$routed_files" -gt 0 && "$emptied" -gt 0 ]]; then
    msg="notes: route $routed_total item(s) from $routed_files dump(s), archive $emptied empty dump(s)"
  elif [[ "$routed_files" -gt 0 ]]; then
    msg="notes: route $routed_total item(s) from $routed_files dump(s)"
  else
    msg="notes: archive $emptied empty dump(s)"
  fi
  run git -C "$NOTES_DIR" add -A
  run git -C "$NOTES_DIR" commit -q -m "$msg"
  # git push is host-agnostic: it reads origin and does the right thing whether
  # that is GitHub, Bitbucket, or a bare repo on a NAS. No special-casing here.
  if [[ "$do_push" == "true" ]]; then
    run git -C "$NOTES_DIR" push
  fi
fi
