// VS Code user settings. Symlinked to the platform's Code/User/settings.json.
//
// VS Code rewrites this file whenever you change a setting from the UI. It edits
// through the symlink, so those changes land in the repo -- `git diff` after a
// settings-tweaking session, and commit what you meant to keep. If VS Code ever
// replaces the link with a plain file, `make doctor` reports it as
// "exists but is not a symlink".
//
// Machine-specific settings do not belong here; there is no *.local layer for
// VS Code. Use a Workspace settings file (.vscode/settings.json) per project, or
// Profiles for a per-machine variant.
{
  // --- Theme -----------------------------------------------------------------
  // Ships with this repo as a local extension; see vscode/extensions/muted-ink.
  // If VS Code is running when that extension is uninstalled, it *deletes* this
  // key from the file rather than leaving a dangling theme name.
  "workbench.colorTheme": "Muted Ink",
  "window.autoDetectColorScheme": false,

  // --- Typography ------------------------------------------------------------
  // Ghostty *bundles* JetBrains Mono, so `font-family = JetBrains Mono` works
  // there even when the font is not installed system-wide. VS Code bundles
  // nothing: an unresolvable family silently falls back through fontconfig, and
  // on this machine `fc-match "JetBrains Mono"` answers *Noto Sans* -- a
  // proportional font. Hence a real stack, ending in fonts that exist.
  // 'JetBrainsMono Nerd Font Mono' first: bootstrap installs it (a superset of
  // JetBrains Mono with Powerline/icon glyphs), so the terminal's status-line
  // glyph mode renders. Plain 'JetBrains Mono' stays next as the fallback.
  "editor.fontFamily": "'JetBrainsMono Nerd Font Mono', 'JetBrains Mono', 'Source Code Pro', 'Adwaita Mono', 'Liberation Mono', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.6,
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font Mono', 'JetBrains Mono', 'Source Code Pro', 'Adwaita Mono', monospace",
  "terminal.integrated.fontSize": 14,

  // --- Minimal chrome --------------------------------------------------------
  // Strip the ornaments that duplicate information the editor already shows.
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  "workbench.activityBar.location": "top",
  "workbench.layoutControl.enabled": false,
  "workbench.editor.editorActionsLocation": "hidden",
  "window.commandCenter": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,

  // Tabs: flat, no boxes. The theme marks the active one with a top rule.
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabSizing": "shrink",
  // Preserved from your existing settings: a single click opens a real tab
  // rather than an italic preview tab that the next click replaces.
  "workbench.editor.enablePreview": false,

  "workbench.tree.renderIndentGuides": "none",
  "workbench.list.smoothScrolling": true,
  "explorer.compactFolders": false,

  // --- Editor surface --------------------------------------------------------
  "editor.renderLineHighlight": "gutter",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.scrollBeyondLastLine": false,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.renderWhitespace": "boundary",
  "editor.guides.indentation": true,
  "editor.guides.bracketPairs": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.stickyScroll.enabled": true,
  "editor.occurrencesHighlight": "singleFile",
  "editor.rulers": [80, 100],

  // --- Files -----------------------------------------------------------------
  // Matches what the other tools in this repo already enforce on save.
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  // Deliberately off: formatting is a per-project decision, and a global
  // formatOnSave rewrites files in repos that never asked for it.
  "editor.formatOnSave": false,

  // --- Terminal --------------------------------------------------------------
  // These mirror ghostty/config.ghostty, so the integrated terminal behaves like
  // the one outside the window: `cursor-style = block`, `cursor-style-blink =
  // false`, `copy-on-select = true`. A blinking cursor here and a steady one in
  // Ghostty is the kind of mismatch you feel before you can name it.
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.smoothScrolling": true,

  // --- One terminal, one tmux session per project -----------------------------
  // vscode/bin/dev-shell, not $SHELL. A flatpak VS Code runs the integrated
  // terminal *inside the sandbox*, where PATH is only /app/bin:/usr/bin -- no
  // tmux, no nvim, no ripgrep, no fzf, no claude. dev-shell hops to the host and
  // attaches a tmux session named for the project directory, so the terminal in
  // here and `tmux attach` from Ghostty are the same session. See docs/VSCODE.md.
  //
  // ${env:HOME} because a profile `path` may not begin with `~`.
  "terminal.integrated.profiles.linux": {
    "dev (tmux)": { "path": "${env:HOME}/.local/bin/dev-shell" }
  },
  "terminal.integrated.defaultProfile.linux": "dev (tmux)",
  "terminal.integrated.profiles.osx": {
    "dev (tmux)": { "path": "${env:HOME}/.local/bin/dev-shell" }
  },
  "terminal.integrated.defaultProfile.osx": "dev (tmux)",

  // On. When VS Code restores a terminal after a restart, it re-runs the profile
  // -- dev-shell -- which `has-session` detects and *attaches* to. The tmux server
  // is a host daemon (started via host-spawn, outside VS Code's pty), so it
  // outlives the editor: quit VS Code, reopen, and the restored terminal reattaches
  // the same session with every pane and process still running. Attach is
  // non-destructive and dev-shell only splits on first create, so restore never
  // duplicates panes. (This was briefly false, on the wrong theory that restore
  // would fight tmux; it reconnects to it.)
  "terminal.integrated.enablePersistentSessions": true,

  // Terminals to the right, not the bottom: the editor and Explorer keep the
  // left, terminals sit beside them full-height. Split the panel to get Claude
  // Code in one and a shell in the other, both visible at once.
  "workbench.panel.defaultLocation": "right",

  // Note on tmux and keybindings: VS Code binds ctrl+b to toggleSidebarVisibility
  // and handles it before the shell sees it, which would eat tmux's stock prefix.
  // tmux/tmux.conf already rebinds the prefix to ctrl+a and unbinds ctrl+b, and
  // ctrl+a is not a VS Code terminal binding, so they coexist. If a keybinding is
  // ever swallowed, "terminal.integrated.sendKeybindingsToShell": true sends every
  // chord to the shell instead -- at the cost of VS Code's own shortcuts while the
  // terminal has focus.
  "terminal.integrated.allowChords": true,

  // --- Workbench layout (dotfiles-workbench extension) -------------------------
  // The right-hand terminal is a ready shell; type `claude` yourself. Set here
  // explicitly rather than relying on the extension's manifest default, because
  // VS Code caches an extension's contributed defaults at registration and a
  // window reload does not refresh them -- a default flipped in package.json
  // would not take effect until the extension is reinstalled. An explicit user
  // setting is read live and always wins. Flip to true to auto-launch claude.
  "dotfilesWorkbench.claudeAutostart": false,

  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "chat.agent.enabled": false
}
