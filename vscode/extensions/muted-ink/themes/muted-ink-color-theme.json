  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6b7280", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#7a9b76" }
    },
    {
      "name": "Escape and regexp",
      "scope": ["constant.character.escape", "string.regexp", "string.regexp punctuation"],
      "settings": { "foreground": "#7dabab" }
    },
    {
      "name": "Number, boolean, language constant",
      "scope": ["constant.numeric", "constant.language", "constant.other", "support.constant"],
      "settings": { "foreground": "#c7ae77" }
    },
    {
      "name": "Keyword and storage",
      "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#9a7eaa" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#7aa2a5" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator", "punctuation.accessor"],
      "settings": { "foreground": "#c9d1d9" }
    },
    {
      "name": "Function and method",
      "scope": ["entity.name.function", "support.function", "variable.function", "entity.name.method", "meta.function-call.generic"],
      "settings": { "foreground": "#7e9fbc" }
    },
    {
      "name": "Type, class, interface",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class", "storage.type.class"],
      "settings": { "foreground": "#c7ae77" }
    },
    {
      "name": "Variable and parameter",
      "scope": ["variable", "variable.other", "variable.parameter", "meta.definition.variable"],
      "settings": { "foreground": "#c9d1d9" }
    },
    {
      "name": "Property and object key",
      "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key", "support.type.property-name.json"],
      "settings": { "foreground": "#6f8faf" }
    },
    {
      "name": "Language variable (this, self, super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#aa8cbc", "fontStyle": "italic" }
    },
    {
      "name": "Namespace and module",
      "scope": ["entity.name.namespace", "entity.name.module", "support.module", "entity.name.scope-resolution"],
      "settings": { "foreground": "#7dabab" }
    },
    {
      "name": "Decorator and annotation",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator", "meta.annotation"],
      "settings": { "foreground": "#aa8cbc" }
    },
    {
      "name": "HTML/JSX tag",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#9a7eaa" }
    },
    {
      "name": "HTML/JSX attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#c7ae77" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#c7ae77" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#c47a7a" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#c47a7a", "fontStyle": "strikethrough" }
    },

    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#7aa2a5", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#e6edf3", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#c7ae77", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#7e9fbc", "fontStyle": "underline" }
    },
    {
      "name": "Markdown inline code and fenced block",
      "scope": ["markup.inline.raw", "markup.fenced_code", "markup.raw"],
      "settings": { "foreground": "#c7ae77" }
    },
    {
      "name": "Markdown quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6b7280", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list bullet",
      "scope": ["punctuation.definition.list.begin.markdown", "beginning.punctuation.definition.list"],
      "settings": { "foreground": "#7aa2a5" }
    },
    {
      "name": "Markdown rule",
      "scope": ["meta.separator"],
      "settings": { "foreground": "#263241" }
    },

    {
      "name": "Diff inserted",
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": { "foreground": "#8baf87" }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": { "foreground": "#c47a7a" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed", "markup.changed.diff"],
      "settings": { "foreground": "#c7ae77" }
    },
    {
      "name": "Diff hunk header",
      "scope": ["meta.diff.range", "meta.diff.header"],
      "settings": { "foreground": "#7aa2a5" }
    }
  ],

  "semanticTokenColors": {
    "namespace": "#7dabab",
    "class": "#c7ae77",
    "enum": "#c7ae77",
    "interface": "#c7ae77",
    "struct": "#c7ae77",
    "type": "#c7ae77",
    "typeParameter": "#c7ae77",
    "enumMember": "#c7ae77",
    "function": "#7e9fbc",
    "method": "#7e9fbc",
    "macro": "#aa8cbc",
    "decorator": "#aa8cbc",
    "keyword": "#9a7eaa",
    "operator": "#7aa2a5",
    "string": "#7a9b76",
    "number": "#c7ae77",
    "comment": { "foreground": "#6b7280", "fontStyle": "italic" },
    "variable": "#c9d1d9",
    "variable.readonly": "#c7ae77",
    "parameter": "#c9d1d9",
    "property": "#6f8faf",
    "selfKeyword": { "foreground": "#aa8cbc", "fontStyle": "italic" },
    "*.deprecated": { "strikethrough": true }
  }
}
