# Global git ignore — symlinked to ~/.config/git/ignore.
# Patterns that should never be tracked in ANY repo.

# OS cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# Editor / IDE
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-workspace

# Env / secrets (belt and suspenders — still use per-repo .gitignore)
.env
.env.local
*.pem

# Build / logs / temp
*.log
*.tmp
node_modules/
__pycache__/
.venv/
.direnv/
