# Managed ~/.gitconfig — symlinked from the dotfiles repo (git module).
# Identity and secrets live in ~/.gitconfig.local (untracked), included at the
# BOTTOM of this file — see the note there before moving it.

[user]
	# Intentionally empty here — set name/email in ~/.gitconfig.local.

[init]
	defaultBranch = main

[core]
	# Use delta when installed; fall back to less otherwise.
	pager = delta || less
	# No `editor` here on purpose: unset, git falls back to $VISUAL, then
	# $EDITOR (set by shell/exports.sh), then vi. Setting core.editor to a
	# specific binary here would override that for every machine. Pin one in
	# ~/.gitconfig.local if you want git to differ from your shell's $EDITOR.
	autocrlf = input
	excludesfile = ~/.config/git/ignore

[interactive]
	diffFilter = delta --color-only || cat

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false
	syntax-theme = muted-ink
	# muted-ink derived diff colors
	minus-style = syntax "#3a1d1d"
	minus-emph-style = syntax "#5a2a2a"
	plus-style = syntax "#16301c"
	plus-emph-style = syntax "#1f4a2c"
	line-numbers-minus-style = "#b26a6a"
	line-numbers-plus-style = "#7a9b76"
	line-numbers-zero-style = "#4b5563"
	file-style = "#7aa2a5"
	hunk-header-style = "#6b7280"

[color]
	ui = auto

[pull]
	ff = only

[push]
	default = current
	autoSetupRemote = true

[fetch]
	prune = true

[rebase]
	autosquash = true
	autostash = true

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[commit]
	verbose = true

# Resolve gh through PATH, not an absolute path: Homebrew puts it in
# /opt/homebrew/bin (Apple Silicon) or /usr/local/bin (Intel), never /usr/bin.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

[alias]
	st = status --short --branch
	co = checkout
	sw = switch
	br = branch
	ci = commit
	ca = commit --amend
	unstage = reset HEAD --
	last = log -1 HEAD --stat
	lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) %C(dim white)%an%C(reset) %C(green)(%ar)%C(reset)%C(auto)%d%C(reset) %s'
	ll = log --oneline --graph --decorate -30
	amend = commit --amend --no-edit
	undo = reset --soft HEAD~1
	aliases = config --get-regexp ^alias\\.

# Machine-local: user.name / user.email / signing keys / work overrides.
#
# This include MUST stay last. Git applies an include where it appears, and for
# a single-valued key the last value wins — so an include at the top of the file
# is read first and every setting above would silently beat it. Last means
# ~/.gitconfig.local actually overrides, which is the contract the other modules
# keep too (~/.bashrc.local, local.ghostty).
[include]
	path = ~/.gitconfig.local
